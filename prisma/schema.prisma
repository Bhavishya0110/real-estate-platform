model CallbackRequest {
  id                 String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  contactId          String?   @map("contact_id") @db.Uuid
  leadId             String?   @map("lead_id") @db.Uuid
  conversationId     String?   @map("conversation_id") @db.Uuid
  name               String    @db.VarChar(240)
  phone              String    @db.VarChar(32)
  preferredTimeLabel String    @map("preferred_time_label") @db.VarChar(96)
  preferredFrom      DateTime? @map("preferred_from") @db.Timestamptz(6)
  preferredTo        DateTime? @map("preferred_to") @db.Timestamptz(6)
  message            String?   @db.Text
  unansweredQuestion String?   @map("unanswered_question") @db.Text
  status             String    @default("new") @db.VarChar(32)
  handledById        String?   @map("handled_by_id") @db.Uuid
  handledAt          DateTime? @map("handled_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  contact      Contact?          @relation(fields: [contactId], references: [id], onDelete: SetNull)
  lead         Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation ChatConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  handledBy    User?             @relation("CallbackHandler", fields: [handledById], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([contactId])
  @@map("callback_requests")
}

model SiteVisit {
  id                String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  leadId            String?     @map("lead_id") @db.Uuid
  contactId         String      @map("contact_id") @db.Uuid
  projectId         String      @map("project_id") @db.Uuid
  hostId            String?     @map("host_id") @db.Uuid
  status            VisitStatus @default(REQUESTED)
  scheduledFor      DateTime    @map("scheduled_for") @db.Timestamptz(6)
  durationMinutes   Int         @default(60) @map("duration_minutes") @db.SmallInt
  attendeeCount     Int         @default(1) @map("attendee_count") @db.SmallInt
  transportRequired Boolean     @default(false) @map("transport_required")
  meetingPoint      String?     @map("meeting_point") @db.VarChar(255)
  outcome           String?     @db.Text
  feedbackRating    Int?        @map("feedback_rating") @db.SmallInt
  cancelledReason   String?     @map("cancelled_reason") @db.VarChar(255)
  createdAt         DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  host    User?   @relation(fields: [hostId], references: [id], onDelete: SetNull)

  @@index([scheduledFor, status])
  @@index([projectId, scheduledFor])
  @@index([hostId, scheduledFor])
  @@map("site_visits")
}

// ================================================== ENGAGEMENT & CHAT =======

model FavoriteProject {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  visitorId String   @map("visitor_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  note      String?  @db.VarChar(400)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([visitorId, projectId])
  @@index([projectId])
  @@map("favorite_projects")
}

model ComparisonSet {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  visitorId  String   @map("visitor_id") @db.Uuid
  name       String?  @db.VarChar(140)
  shareToken String?  @unique @map("share_token") @db.VarChar(32)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  visitor Visitor             @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  items   ComparisonSetItem[]

  @@index([visitorId])
  @@map("comparison_sets")
}

model ComparisonSetItem {
  setId     String @map("set_id") @db.Uuid
  projectId String @map("project_id") @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")

  set     ComparisonSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([setId, projectId])
  @@index([projectId])
  @@map("comparison_set_items")
}

model SavedSearch {
