model Department {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug      String  @unique @db.VarChar(96)
  name      String  @unique @db.VarChar(120)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  jobs Job[]

  @@map("departments")
}

model Job {
  id                 String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug               String        @unique @db.VarChar(180)
  title              String        @db.VarChar(200)
  departmentId       String?       @map("department_id") @db.Uuid
  employmentType     String        @map("employment_type") @db.VarChar(32)
  locationText       String        @map("location_text") @db.VarChar(160)
  isRemote           Boolean       @default(false) @map("is_remote")
  experienceLabel    String?       @map("experience_label") @db.VarChar(96)
  experienceMinYears Int?          @map("experience_min_years") @db.SmallInt
  experienceMaxYears Int?          @map("experience_max_years") @db.SmallInt
  salaryMinMinor     BigInt?       @map("salary_min_minor")
  salaryMaxMinor     BigInt?       @map("salary_max_minor")
  salaryIsPublic     Boolean       @default(false) @map("salary_is_public")
  summary            String        @db.Text
  responsibilities   String[]
  requirements       String[]
  benefits           String[]
  openings           Int           @default(1) @db.SmallInt
  publishStatus      PublishStatus @default(DRAFT) @map("publish_status")
  publishedAt        DateTime?     @map("published_at") @db.Timestamptz(6)
