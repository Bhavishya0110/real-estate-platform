model JobApplication {
  id               String            @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  reference        String            @unique @db.VarChar(24)
  jobId            String            @map("job_id") @db.Uuid
  contactId        String?           @map("contact_id") @db.Uuid
  fullName         String            @map("full_name") @db.VarChar(240)
  email            String            @db.Citext
  phone            String            @db.VarChar(32)
  resumeMediaId    String?           @map("resume_media_id") @db.Uuid
  coverLetter      String?           @map("cover_letter") @db.Text
  portfolioUrl     String?           @map("portfolio_url") @db.Text
  linkedinUrl      String?           @map("linkedin_url") @db.Text
  currentCompany   String?           @map("current_company") @db.VarChar(180)
  currentCtcMinor  BigInt?           @map("current_ctc_minor")
  expectedCtcMinor BigInt?           @map("expected_ctc_minor")
  noticePeriodDays Int?              @map("notice_period_days") @db.SmallInt
  status           ApplicationStatus @default(RECEIVED)
  rating           Int?              @db.SmallInt
  reviewerId       String?           @map("reviewer_id") @db.Uuid
  internalNotes    String?           @map("internal_notes") @db.Text
  source           String?           @db.VarChar(64)
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)

  job          Job                       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  contact      Contact?                  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  resume       MediaAsset?               @relation(fields: [resumeMediaId], references: [id], onDelete: SetNull)
  reviewer     User?                     @relation("ApplicationReviewer", fields: [reviewerId], references: [id], onDelete: SetNull)
  stageHistory ApplicationStageHistory[]

  @@unique([jobId, email])
  @@index([jobId, status])
  @@index([status, createdAt])
  @@map("job_applications")
}

model ApplicationStageHistory {
