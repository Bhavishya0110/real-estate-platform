model ValuePillar {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug        String  @unique @db.VarChar(96)
  title       String  @db.VarChar(160)
  description String  @db.Text
  iconName    String? @map("icon_name") @db.VarChar(64)
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  @@map("value_pillars")
}

model CompanyStat {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug      String  @unique @db.VarChar(96)
  label     String  @db.VarChar(160)
  value     Int
  suffix    String? @db.VarChar(16)
  sortOrder Int     @default(0) @map("sort_order")
  isActive  Boolean @default(true) @map("is_active")

  @@map("company_stats")
}

model LegalDocument {
  id            String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug          String        @db.VarChar(96)
  version       String        @db.VarChar(32)
  title         String        @db.VarChar(200)
  effectiveFrom DateTime      @map("effective_from") @db.Date
  publishStatus PublishStatus @default(DRAFT) @map("publish_status")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)

  sections LegalDocumentSection[]

  @@unique([slug, version])
  @@index([slug, effectiveFrom])
  @@map("legal_documents")
}

model LegalDocumentSection {
  id         String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  documentId String   @map("document_id") @db.Uuid
  heading    String   @db.VarChar(240)
  body       String   @db.Text
  items      String[]
  sortOrder  Int      @default(0) @map("sort_order")

  document LegalDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, sortOrder])
  @@map("legal_document_sections")
}

// ============================================== CMS, SETTINGS & OPS =========

model HomepageSection {
  id            String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  key           String        @unique @db.VarChar(64)
  name          String        @db.VarChar(140)
  componentType String        @map("component_type") @db.VarChar(64)
  config        Json          @db.JsonB
  isVisible     Boolean       @default(true) @map("is_visible")
  sortOrder     Int           @default(0) @map("sort_order")
  publishStatus PublishStatus @default(PUBLISHED) @map("publish_status")
  updatedById   String?       @map("updated_by_id") @db.Uuid
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isVisible, sortOrder])
  @@map("homepage_sections")
}

model NavigationMenu {
  id       String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug     String  @unique @db.VarChar(64)
  name     String  @db.VarChar(120)
  location String  @db.VarChar(32)
  isActive Boolean @default(true) @map("is_active")

  items NavigationItem[]

  @@map("navigation_menus")
}

model NavigationItem {
  id                 String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  menuId             String  @map("menu_id") @db.Uuid
  parentId           String? @map("parent_id") @db.Uuid
  label              String  @db.VarChar(120)
  href               String  @db.VarChar(500)
  target             String? @db.VarChar(16)
  iconName           String? @map("icon_name") @db.VarChar(64)
  isVisible          Boolean @default(true) @map("is_visible")
  requiresPermission String? @map("requires_permission") @db.VarChar(96)
  sortOrder          Int     @default(0) @map("sort_order")

  menu     NavigationMenu   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  parent   NavigationItem?  @relation("NavTree", fields: [parentId], references: [id], onDelete: Cascade)
  children NavigationItem[] @relation("NavTree")

  @@index([menuId, parentId, sortOrder])
  @@map("navigation_items")
}

model SeoSetting {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  path            String?  @unique @db.VarChar(500)
  projectId       String?  @unique @map("project_id") @db.Uuid
  blogPostId      String?  @unique @map("blog_post_id") @db.Uuid
  metaTitle       String?  @map("meta_title") @db.VarChar(240)
  metaDescription String?  @map("meta_description") @db.VarChar(500)
  canonicalUrl    String?  @map("canonical_url") @db.Text
  ogTitle         String?  @map("og_title") @db.VarChar(240)
  ogDescription   String?  @map("og_description") @db.VarChar(500)
  ogImageMediaId  String?  @map("og_image_media_id") @db.Uuid
  twitterCard     String?  @map("twitter_card") @db.VarChar(32)
  noIndex         Boolean  @default(false) @map("no_index")
  noFollow        Boolean  @default(false) @map("no_follow")
  structuredData  Json?    @map("structured_data") @db.JsonB
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  project  Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  blogPost BlogPost?   @relation(fields: [blogPostId], references: [id], onDelete: Cascade)
  ogImage  MediaAsset? @relation(fields: [ogImageMediaId], references: [id], onDelete: SetNull)

  @@map("seo_settings")
}

model Redirect {
  id         String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  fromPath   String    @unique @map("from_path") @db.VarChar(500)
  toPath     String    @map("to_path") @db.VarChar(500)
  statusCode Int       @default(301) @map("status_code") @db.SmallInt
  isActive   Boolean   @default(true) @map("is_active")
  hitCount   Int       @default(0) @map("hit_count")
  lastHitAt  DateTime? @map("last_hit_at") @db.Timestamptz(6)
  note       String?   @db.VarChar(255)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([isActive])
  @@map("redirects")
}

model SiteSetting {
  id          String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  key         String      @unique @db.VarChar(120)
  value       String?     @db.Text
  valueJson   Json?       @map("value_json") @db.JsonB
  type        SettingType @default(STRING)
  group       String      @db.VarChar(64)
  label       String      @db.VarChar(160)
  description String?     @db.Text
  isPublic    Boolean     @default(false) @map("is_public")
  isSecret    Boolean     @default(false) @map("is_secret")
  updatedById String?     @map("updated_by_id") @db.Uuid
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([group, isPublic])
  @@map("site_settings")
}

model SocialLink {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  platform  String  @unique @db.VarChar(48)
  label     String  @db.VarChar(96)
  url       String  @db.Text
  iconName  String? @map("icon_name") @db.VarChar(64)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  @@map("social_links")
}

model Office {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug         String   @unique @db.VarChar(96)
  name         String   @db.VarChar(160)
  type         String   @db.VarChar(32)
  addressLine1 String   @map("address_line1") @db.VarChar(255)
  addressLine2 String?  @map("address_line2") @db.VarChar(255)
  city         String   @db.VarChar(120)
  state        String   @db.VarChar(120)
  pinCode      String   @map("pin_code") @db.VarChar(10)
  phone        String?  @db.VarChar(32)
  email        String?  @db.Citext
  whatsapp     String?  @db.VarChar(20)
  mapsUrl      String?  @map("maps_url") @db.Text
  latitude     Decimal? @db.Decimal(9, 6)
  longitude    Decimal? @db.Decimal(9, 6)
  openingHours Json?    @map("opening_hours") @db.JsonB
  isPrimary    Boolean  @default(false) @map("is_primary")
  isActive     Boolean  @default(true) @map("is_active")
  sortOrder    Int      @default(0) @map("sort_order")

  @@map("offices")
}

model Integration {
  id               String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug             String    @unique @db.VarChar(64)
  name             String    @db.VarChar(140)
  isEnabled        Boolean   @default(false) @map("is_enabled")
  config           Json?     @db.JsonB
  encryptedSecrets Bytes?    @map("encrypted_secrets")
  lastSyncedAt     DateTime? @map("last_synced_at") @db.Timestamptz(6)
  lastError        String?   @map("last_error") @db.Text
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("integrations")
}

model FeatureFlag {
  id             String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  key            String   @unique @db.VarChar(96)
  description    String?  @db.Text
  isEnabled      Boolean  @default(false) @map("is_enabled")
  rolloutPercent Int      @default(0) @map("rollout_percent") @db.SmallInt
  environments   String[]
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("feature_flags")
}

model ContentRevision {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  entityType  String   @map("entity_type") @db.VarChar(64)
  entityId    String   @map("entity_id") @db.Uuid
  version     Int
  snapshot    Json     @db.JsonB
  changeNote  String?  @map("change_note") @db.VarChar(255)
  isPublished Boolean  @default(false) @map("is_published")
  createdById String?  @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy User? @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@unique([entityType, entityId, version])
  @@index([entityType, entityId, createdAt])
  @@map("content_revisions")
}

model Notification {
  id         String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId     String?   @map("user_id") @db.Uuid
  type       String    @db.VarChar(64)
  title      String    @db.VarChar(240)
  body       String?   @db.Text
  entityType String?   @map("entity_type") @db.VarChar(64)
  entityId   String?   @map("entity_id") @db.Uuid
  actionUrl  String?   @map("action_url") @db.Text
  priority   String    @default("normal") @db.VarChar(16)
  readAt     DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user       User?                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries NotificationDelivery[]

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
  @@map("notifications")
}

model NotificationDelivery {
  id                String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  notificationId    String              @map("notification_id") @db.Uuid
  channel           NotificationChannel
  status            DeliveryStatus      @default(PENDING)
  destination       String?             @db.VarChar(255)
  providerMessageId String?             @map("provider_message_id") @db.VarChar(180)
  attempts          Int                 @default(0) @db.SmallInt
  lastError         String?             @map("last_error") @db.Text
  sentAt            DateTime?           @map("sent_at") @db.Timestamptz(6)
  deliveredAt       DateTime?           @map("delivered_at") @db.Timestamptz(6)
  createdAt         DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([notificationId])
  @@map("notification_deliveries")
}

model NotificationPreference {
  id        String              @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String              @map("user_id") @db.Uuid
  type      String              @db.VarChar(64)
  channel   NotificationChannel
  isEnabled Boolean             @default(true) @map("is_enabled")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@map("notification_preferences")
}
