model SavedSearchAlert {
  id                String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  savedSearchId     String    @map("saved_search_id") @db.Uuid
  matchedProjectIds String[]  @map("matched_project_ids") @db.Uuid
  sentAt            DateTime? @map("sent_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  savedSearch SavedSearch @relation(fields: [savedSearchId], references: [id], onDelete: Cascade)

  @@index([savedSearchId, createdAt])
  @@map("saved_search_alerts")
}

model ProjectView {
  id        String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  visitorId String?  @map("visitor_id") @db.Uuid
  source    String?  @db.VarChar(48)
  dwellMs   Int?     @map("dwell_ms")
  viewedAt  DateTime @default(now()) @map("viewed_at") @db.Timestamptz(6)

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  visitor Visitor? @relation(fields: [visitorId], references: [id], onDelete: SetNull)

  @@index([projectId, viewedAt])
  @@index([visitorId, viewedAt])
  @@map("project_views")
}

model ChatConversation {
  id              String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  visitorId       String?   @map("visitor_id") @db.Uuid
  leadId          String?   @unique @map("lead_id") @db.Uuid
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  endedAt         DateTime? @map("ended_at") @db.Timestamptz(6)
  messageCount    Int       @default(0) @map("message_count") @db.SmallInt
  unansweredCount Int       @default(0) @map("unanswered_count") @db.SmallInt
  didEscalate     Boolean   @default(false) @map("did_escalate")
  landingPage     String?   @map("landing_page") @db.Text
  userAgent       String?   @map("user_agent") @db.Text

  visitor    Visitor?          @relation(fields: [visitorId], references: [id], onDelete: SetNull)
  lead       Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages   ChatMessage[]
  callbacks  CallbackRequest[]
  unanswered UnansweredQuery[]

  @@index([visitorId, startedAt])
  @@index([startedAt])
  @@index([didEscalate])
  @@map("chat_conversations")
}

model ChatMessage {
  id                  String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  conversationId      String   @map("conversation_id") @db.Uuid
  role                ChatRole
  sequence            Int      @db.SmallInt
  content             String   @db.Text
  matchedIntent       String?  @map("matched_intent") @db.VarChar(64)
  wasUnanswered       Boolean  @default(false) @map("was_unanswered")
  suggestedProjectIds String[] @map("suggested_project_ids") @db.Uuid
  latencyMs           Int?     @map("latency_ms")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation ChatConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  feedback     ChatFeedback[]

  @@unique([conversationId, sequence])
  @@index([conversationId, createdAt])
  @@index([wasUnanswered])
  @@map("chat_messages")
}

model ChatFeedback {
  id        String         @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  messageId String         @map("message_id") @db.Uuid
  rating    FeedbackRating
  reason    String?        @db.VarChar(400)
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([rating, createdAt])
  @@map("chat_feedback")
}

model UnansweredQuery {
  id               String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  conversationId   String?   @map("conversation_id") @db.Uuid
  queryText        String    @map("query_text") @db.Text
  normalizedText   String    @map("normalized_text") @db.VarChar(500)
  occurrenceCount  Int       @default(1) @map("occurrence_count")
  resolvedIntentId String?   @map("resolved_intent_id") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz(6)
  resolvedById     String?   @map("resolved_by_id") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt       DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)

  conversation   ChatConversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  resolvedIntent ChatbotIntent?    @relation(fields: [resolvedIntentId], references: [id], onDelete: SetNull)
  resolvedBy     User?             @relation(fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([normalizedText])
  @@index([resolvedAt, occurrenceCount])
  @@map("unanswered_queries")
}

model ChatbotIntent {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug         String   @unique @db.VarChar(64)
  name         String   @db.VarChar(140)
  patterns     String[]
  responseText String   @map("response_text") @db.Text
  actions      Json?    @db.JsonB
  priority     Int      @default(0) @db.SmallInt
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  resolvedQueries UnansweredQuery[]

  @@map("chatbot_intents")
}

