model Author {
  id            String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId        String? @unique @map("user_id") @db.Uuid
  slug          String  @unique @db.VarChar(140)
  name          String  @db.VarChar(180)
  title         String? @db.VarChar(160)
  bio           String? @db.Text
  avatarMediaId String? @map("avatar_media_id") @db.Uuid
  isActive      Boolean @default(true) @map("is_active")

  user   User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  avatar MediaAsset? @relation(fields: [avatarMediaId], references: [id], onDelete: SetNull)
  posts  BlogPost[]

  @@map("authors")
}

model BlogCategory {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug        String  @unique @db.VarChar(120)
  name        String  @unique @db.VarChar(140)
  description String? @db.Text
  sortOrder   Int     @default(0) @map("sort_order")
  isActive    Boolean @default(true) @map("is_active")

  posts BlogPost[]

  @@map("blog_categories")
}

model BlogPost {
  id              String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug            String        @unique @db.VarChar(180)
  title           String        @db.VarChar(260)
  excerpt         String        @db.Text
  content         Json          @db.JsonB
  contentText     String?       @map("content_text") @db.Text
  categoryId      String?       @map("category_id") @db.Uuid
  authorId        String?       @map("author_id") @db.Uuid
  coverMediaId    String?       @map("cover_media_id") @db.Uuid
  readTimeMinutes Int?          @map("read_time_minutes") @db.SmallInt
  publishStatus   PublishStatus @default(DRAFT) @map("publish_status")
  publishedAt     DateTime?     @map("published_at") @db.Timestamptz(6)
  scheduledFor    DateTime?     @map("scheduled_for") @db.Timestamptz(6)
  viewCount       Int           @default(0) @map("view_count")
  isFeatured      Boolean       @default(false) @map("is_featured")
  /// Trigger-maintained; see the init migration.
  searchVector    Unsupported("tsvector")? @map("search_vector")
  createdById     String?       @map("created_by_id") @db.Uuid
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?     @map("deleted_at") @db.Timestamptz(6)

  category   BlogCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author     Author?       @relation(fields: [authorId], references: [id], onDelete: SetNull)
  cover      MediaAsset?   @relation("BlogCover", fields: [coverMediaId], references: [id], onDelete: SetNull)
  tags       BlogPostTag[]
  seoSetting SeoSetting?

  @@index([publishStatus, publishedAt])
  @@index([categoryId, publishStatus])
  @@index([authorId])
  @@index([deletedAt])
  @@map("blog_posts")
}

model Tag {
  id   String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug String @unique @db.VarChar(96)
  name String @unique @db.VarChar(120)

  posts BlogPostTag[]

  @@map("tags")
}

model BlogPostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  post BlogPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag  Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId])
  @@map("blog_post_tags")
}

model Testimonial {
