  visitor Visitor?           @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  contact Contact?           @relation(fields: [contactId], references: [id], onDelete: Cascade)
  alerts  SavedSearchAlert[]

  @@index([visitorId])
  @@index([alertsEnabled, lastRunAt])
