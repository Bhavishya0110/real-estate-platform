// =============================================================================
// JMS GROUP — DATABASE SCHEMA
//
// The executable form of the approved Phase 6 architecture. Rationale for each
// table lives in the design document; this file is the source of truth for
// columns, types, keys, indexes and constraints.
//
// CONNECTIONS
//   url       — pooled (PgBouncer, 6543). The application uses this: serverless
//               functions open a connection per invocation and would otherwise
//               exhaust max_connections.
//   directUrl — session mode (5432). Migrations only — Prisma Migrate takes
//               advisory locks and runs DDL in transactions, neither of which
//               survives transaction-mode pooling.
//
// CONVENTIONS
//   • Tables and columns are snake_case in the database (@@map / @map) and
//     camelCase in TypeScript. The raw SQL in the migration references the
//     database names directly.
//   • Primary keys are UUID v7 — globally unique but time-ordered, so B-tree
//     inserts stay local instead of scattering pages the way v4 does. The
//     uuid_generate_v7() function is created at the top of the first migration.
//   • Money is BIGINT minor units (paise). Never float.
//   • Content tables carry publish_status + published_at; catalogue and content
//     soft-delete via deleted_at, person data hard-deletes for DPDP erasure.
// =============================================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto, pg_trgm, unaccent, citext]
}

// ============================================================ ENUMS ==========

enum PublishStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED

  @@map("publish_status")
}

enum UserStatus {
  INVITED
  ACTIVE
  SUSPENDED
  DISABLED

  @@map("user_status")
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  ARCHIVE

  @@map("media_kind")
}

enum MediaRole {
  HERO
  GALLERY
  THUMBNAIL
  MASTER_PLAN
  LOCATION_MAP
  LOGO
  WALKTHROUGH
  DRONE

  @@map("media_role")
}

enum DocumentKind {
  BROCHURE
  FLOOR_PLAN
  PRICE_SHEET
  RERA_CERTIFICATE
  LEGAL_APPROVAL
  PAYMENT_PLAN
  FACT_SHEET

  @@map("document_kind")
}

enum AccessLevel {
  PUBLIC
  LEAD_GATED
  AUTHENTICATED
  INTERNAL

  @@map("access_level")
}

enum DatePrecision {
  DAY
  MONTH
  QUARTER
  YEAR

  @@map("date_precision")
}

enum AreaUnit {
  SQFT
  SQM
  SQYD
  ACRE

  @@map("area_unit")
}

enum Currency {
  INR

  @@map("currency")
}

enum ChatRole {
  USER
  ASSISTANT
  SYSTEM

  @@map("chat_role")
}

enum FeedbackRating {
  HELPFUL
  NOT_HELPFUL

  @@map("feedback_rating")
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
  PUSH

  @@map("notification_channel")
}

enum DeliveryStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
  BOUNCED

  @@map("delivery_status")
}

enum ActivityType {
  NOTE
  CALL
  EMAIL
  WHATSAPP
  SMS
  MEETING
  SITE_VISIT
  STAGE_CHANGE
  ASSIGNMENT
  FILE
  SYSTEM

  @@map("activity_type")
}

enum ConsentPurpose {
  TRANSACTIONAL
  MARKETING
  ANALYTICS
  PROFILING

  @@map("consent_purpose")
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  RESTORE
  LOGIN
  LOGOUT
  LOGIN_FAILED
  PERMISSION_CHANGE
  EXPORT

  @@map("audit_action")
}

enum ApplicationStatus {
  RECEIVED
  SCREENING
  INTERVIEWING
  OFFERED
  HIRED
  REJECTED
  WITHDRAWN

  @@map("application_status")
}

enum VisitStatus {
  REQUESTED
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  CANCELLED

  @@map("visit_status")
}

enum TourProvider {
  MATTERPORT
  KUULA
  CUSTOM_IFRAME
  YOUTUBE_360

  @@map("tour_provider")
}

enum SettingType {
  STRING
  NUMBER
  BOOLEAN
  JSON
  URL
  EMAIL
  PHONE
  RICH_TEXT

  @@map("setting_type")
}

// ============================================= IDENTITY, ACCESS & AUDIT ======

model User {
  id                String     @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  email             String     @unique @db.Citext
  name              String     @db.VarChar(160)
  phone             String?    @db.VarChar(20)
  passwordHash      String     @map("password_hash") @db.VarChar(255)
  passwordChangedAt DateTime?  @map("password_changed_at") @db.Timestamptz(6)
  avatarMediaId     String?    @map("avatar_media_id") @db.Uuid
  status            UserStatus @default(INVITED)
  emailVerifiedAt   DateTime?  @map("email_verified_at") @db.Timestamptz(6)
  mfaSecret         String?    @map("mfa_secret") @db.VarChar(255)
  mfaEnabledAt      DateTime?  @map("mfa_enabled_at") @db.Timestamptz(6)
  failedLoginCount  Int        @default(0) @map("failed_login_count") @db.SmallInt
  lockedUntil       DateTime?  @map("locked_until") @db.Timestamptz(6)
  lastLoginAt       DateTime?  @map("last_login_at") @db.Timestamptz(6)
  timezone          String     @default("Asia/Kolkata") @db.VarChar(64)
  createdById       String?    @map("created_by_id") @db.Uuid
  createdAt         DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt         DateTime?  @map("deleted_at") @db.Timestamptz(6)

  avatar             MediaAsset?          @relation("UserAvatar", fields: [avatarMediaId], references: [id], onDelete: SetNull)
  createdBy          User?                @relation("UserCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdUsers       User[]               @relation("UserCreatedBy")
  roles              UserRole[]
  permissionGrants   UserPermission[]
  sessions           Session[]
  resetTokens        PasswordResetToken[]
  auditLogs          AuditLog[]
  ownedLeads         Lead[]               @relation("LeadOwner")
  leadActivities     LeadActivity[]
  assignmentsMade    LeadAssignment[]     @relation("AssignedBy")
  assignmentsGot     LeadAssignment[]     @relation("AssignedTo")
  projectAssignments ProjectAssignment[]
  uploadedMedia      MediaAsset[]         @relation("MediaUploader")
  authorProfile      Author?
  notifications      Notification[]
  notificationPrefs  NotificationPreference[]
  apiKeys            ApiKey[]
  hostedVisits       SiteVisit[]
  revisions          ContentRevision[]
  priceChanges       ProjectPriceHistory[]
  reviewedApps       JobApplication[]     @relation("ApplicationReviewer")
  appStageChanges    ApplicationStageHistory[]
  handledCallbacks   CallbackRequest[]    @relation("CallbackHandler")
  resolvedQueries    UnansweredQuery[]

  @@index([status, deletedAt])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id           String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug         String   @unique @db.VarChar(64)
  name         String   @db.VarChar(96)
  description  String?  @db.Text
  parentRoleId String?  @map("parent_role_id") @db.Uuid
  isSystem     Boolean  @default(false) @map("is_system")
  rank         Int      @default(0) @db.SmallInt
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  parentRole  Role?            @relation("RoleHierarchy", fields: [parentRoleId], references: [id], onDelete: SetNull)
  childRoles  Role[]           @relation("RoleHierarchy")
  users       UserRole[]
  permissions RolePermission[]

  @@index([parentRoleId])
  @@map("roles")
}

model Permission {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  resource    String  @db.VarChar(64)
  action      String  @db.VarChar(32)
  description String? @db.Text
  isSystem    Boolean @default(true) @map("is_system")

  roles RolePermission[]
  users UserPermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String @map("role_id") @db.Uuid
  permissionId String @map("permission_id") @db.Uuid

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model UserRole {
  userId    String    @map("user_id") @db.Uuid
  roleId    String    @map("role_id") @db.Uuid
  scopeType String?   @map("scope_type") @db.VarChar(32)
  scopeId   String?   @map("scope_id") @db.Uuid
  grantedAt DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@index([expiresAt])
  @@map("user_roles")
}

model UserPermission {
  userId       String    @map("user_id") @db.Uuid
  permissionId String    @map("permission_id") @db.Uuid
  effect       Boolean
  reason       String?   @db.Text
  grantedAt    DateTime  @default(now()) @map("granted_at") @db.Timestamptz(6)
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz(6)

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([userId, permissionId])
  @@map("user_permissions")
}

model Session {
  id            String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId        String    @map("user_id") @db.Uuid
  tokenHash     String    @unique @map("token_hash") @db.VarChar(64)
  ipAddress     String?   @map("ip_address") @db.Inet
  userAgent     String?   @map("user_agent") @db.Text
  deviceLabel   String?   @map("device_label") @db.VarChar(120)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastSeenAt    DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz(6)
  expiresAt     DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt     DateTime? @map("revoked_at") @db.Timestamptz(6)
  revokedReason String?   @map("revoked_reason") @db.VarChar(120)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
  @@map("sessions")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdIp String?   @map("created_ip") @db.Inet

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model LoginAttempt {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  email       String   @db.Citext
  userId      String?  @map("user_id") @db.Uuid
  successful  Boolean
  failureCode String?  @map("failure_code") @db.VarChar(40)
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.Text
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz(6)

  @@index([email, attemptedAt])
  @@index([ipAddress, attemptedAt])
  @@map("login_attempts")
}

model AuditLog {
  id          String      @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  actorId     String?     @map("actor_id") @db.Uuid
  actorEmail  String?     @map("actor_email") @db.Citext
  action      AuditAction
  entityType  String      @map("entity_type") @db.VarChar(64)
  entityId    String?     @map("entity_id") @db.Uuid
  entityLabel String?     @map("entity_label") @db.VarChar(255)
  before      Json?       @db.JsonB
  after       Json?       @db.JsonB
  diffKeys    String[]    @map("diff_keys")
  ipAddress   String?     @map("ip_address") @db.Inet
  userAgent   String?     @map("user_agent") @db.Text
  requestId   String?     @map("request_id") @db.VarChar(64)
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId, createdAt])
  @@index([actorId, createdAt])
  @@index([action, createdAt])
  @@index([createdAt])
  @@map("audit_logs")
}

model ApiKey {
  id          String    @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  name        String    @db.VarChar(120)
  keyPrefix   String    @unique @map("key_prefix") @db.VarChar(12)
  keyHash     String    @unique @map("key_hash") @db.VarChar(64)
  scopes      String[]
  createdById String    @map("created_by_id") @db.Uuid
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz(6)
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6)
  revokedAt   DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  createdBy User @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([revokedAt])
  @@map("api_keys")
}

// ======================================================= PROJECTS ===========

model Project {
  id                 String        @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug               String        @unique @db.VarChar(140)
  name               String        @db.VarChar(180)
  categoryId         String        @map("category_id") @db.Uuid
  locationId         String?       @map("location_id") @db.Uuid
  projectStatusId    String        @map("project_status_id") @db.Uuid
  publishStatus      PublishStatus @default(DRAFT) @map("publish_status")
  publishedAt        DateTime?     @map("published_at") @db.Timestamptz(6)

  tagline            String?       @db.VarChar(220)
  description        String        @db.Text
  longDescription    String?       @map("long_description") @db.Text

  addressLine        String?       @map("address_line") @db.VarChar(255)
  displayLocality    String        @map("display_locality") @db.VarChar(180)
  pinCode            String?       @map("pin_code") @db.VarChar(10)
  latitude           Decimal?      @db.Decimal(9, 6)
  longitude          Decimal?      @db.Decimal(9, 6)

  priceFromMinor     BigInt?       @map("price_from_minor")
  priceToMinor       BigInt?       @map("price_to_minor")
  currency           Currency      @default(INR)
  priceLabelOverride String?       @map("price_label_override") @db.VarChar(120)
  priceOnRequest     Boolean       @default(false) @map("price_on_request")

  areaMin            Decimal?      @map("area_min") @db.Decimal(12, 2)
  areaMax            Decimal?      @map("area_max") @db.Decimal(12, 2)
  areaUnit           AreaUnit      @default(SQFT) @map("area_unit")

  possessionOn        DateTime?     @map("possession_on") @db.Date
  possessionPrecision DatePrecision @default(MONTH) @map("possession_precision")
  /// Editorial phrasing that no date can reproduce — "Ready for Fit-out",
  /// "Phase-wise from 2026", "Immediate Registration". Applies the same rule the
  /// design sets for price_label_override: derive the label from the fact where
  /// possible, and retain the original only where it cannot be reproduced.
  /// Six of fourteen seeded projects need it, so dropping it would silently
  /// rewrite what the site says about handover.
  possessionLabelOverride String?   @map("possession_label_override") @db.VarChar(120)
  launchedOn          DateTime?     @map("launched_on") @db.Date

  totalUnits         Int?          @map("total_units")
  availableUnits     Int?          @map("available_units")
  totalAreaAcres     Decimal?      @map("total_area_acres") @db.Decimal(10, 2)
  towerCount         Int?          @map("tower_count") @db.SmallInt
  floorCount         Int?          @map("floor_count") @db.SmallInt

  isFeatured         Boolean       @default(false) @map("is_featured")
  featuredRank       Int?          @map("featured_rank") @db.SmallInt
  isVerified         Boolean       @default(false) @map("is_verified")
  sortOrder          Int           @default(0) @map("sort_order")
  viewCount          Int           @default(0) @map("view_count")

  /// Weighted full-text index, maintained by a trigger (see the init migration).
  /// A plain column rather than GENERATED so Prisma tracks it as an ordinary
  /// column and never proposes dropping it as drift.
  searchVector       Unsupported("tsvector")? @map("search_vector")

  createdById        String?       @map("created_by_id") @db.Uuid
  updatedById        String?       @map("updated_by_id") @db.Uuid
  createdAt          DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt          DateTime?     @map("deleted_at") @db.Timestamptz(6)

  category          ProjectCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  location          Location?             @relation(fields: [locationId], references: [id], onDelete: SetNull)
  projectStatus     ProjectStatus         @relation(fields: [projectStatusId], references: [id], onDelete: Restrict)
  highlights        ProjectHighlight[]
  amenities         ProjectAmenity[]
  unitTypes         ProjectUnitType[]
  nearbyPlaces      NearbyPlace[]
  updates           ConstructionUpdate[]
  reraRegistrations ReraRegistration[]
  priceHistory      ProjectPriceHistory[]
  virtualTours      VirtualTour[]
  media             ProjectMedia[]
  documents         ProjectDocument[]
  assignments       ProjectAssignment[]
  testimonials      Testimonial[]
  faqs              Faq[]
  leads             Lead[]
  favorites         FavoriteProject[]
  comparisonItems   ComparisonSetItem[]
  views             ProjectView[]
  siteVisits        SiteVisit[]
  seoSetting        SeoSetting?

  @@index([publishStatus, deletedAt])
  @@index([categoryId, publishStatus])
  @@index([locationId])
  @@index([projectStatusId])
  @@index([priceFromMinor])
  @@index([possessionOn])
  @@index([isFeatured, featuredRank])
  @@index([deletedAt])
  @@map("projects")
}

/**
 * The editorial feature list shown on a project page.
 *
 * Not derivable from capabilities: "Plot Selector", "Phase Tracker" and "ROI
 * Calculator" are marketing copy chosen per project, and only one of fourteen
 * matched what capability flags would have produced. Deriving them would have
 * silently rewritten thirteen project pages.
 */
model ProjectHighlight {
  id        String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  projectId String @map("project_id") @db.Uuid
  label     String @db.VarChar(120)
  sortOrder Int    @default(0) @map("sort_order")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, label])
  @@index([projectId, sortOrder])
  @@map("project_highlights")
}

model ProjectCategory {
  id            String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug          String  @unique @db.VarChar(64)
  name          String  @unique @db.VarChar(96)
  description   String? @db.Text
  isResidential Boolean @default(true) @map("is_residential")
  isCommercial  Boolean @default(false) @map("is_commercial")
  iconName      String? @map("icon_name") @db.VarChar(64)
  sortOrder     Int     @default(0) @map("sort_order")
  isActive      Boolean @default(true) @map("is_active")

  projects Project[]

  @@map("project_categories")
}

model ProjectStatus {
  id          String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug        String  @unique @db.VarChar(48)
  name        String  @unique @db.VarChar(64)
  colorToken  String? @map("color_token") @db.VarChar(32)
  isSellable  Boolean @default(true) @map("is_sellable")
  isCompleted Boolean @default(false) @map("is_completed")
  sortOrder   Int     @default(0) @map("sort_order")

  projects Project[]

  @@map("project_statuses")
}

model Location {
  id          String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug        String   @unique @db.VarChar(120)
  name        String   @db.VarChar(140)
  type        String   @db.VarChar(32)
  parentId    String?  @map("parent_id") @db.Uuid
  latitude    Decimal? @db.Decimal(9, 6)
  longitude   Decimal? @db.Decimal(9, 6)
  description String?  @db.Text
  isActive    Boolean  @default(true) @map("is_active")
  sortOrder   Int      @default(0) @map("sort_order")

  parent   Location?  @relation("LocationTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Location[] @relation("LocationTree")
  projects Project[]

  @@unique([parentId, name])
  @@index([type])
  @@index([parentId])
  @@map("locations")
}

model AmenityGroup {
  id        String @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug      String @unique @db.VarChar(64)
  name      String @unique @db.VarChar(96)
  sortOrder Int    @default(0) @map("sort_order")

  amenities Amenity[]

  @@map("amenity_groups")
}

model Amenity {
  id        String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug      String  @unique @db.VarChar(96)
  name      String  @unique @db.VarChar(120)
  groupId   String? @map("group_id") @db.Uuid
  iconName  String? @map("icon_name") @db.VarChar(64)
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  group    AmenityGroup?    @relation(fields: [groupId], references: [id], onDelete: SetNull)
  projects ProjectAmenity[]

  @@index([groupId])
  @@map("amenities")
}

model ProjectAmenity {
  projectId     String  @map("project_id") @db.Uuid
  amenityId     String  @map("amenity_id") @db.Uuid
  isHighlighted Boolean @default(false) @map("is_highlighted")
  note          String? @db.VarChar(200)
  sortOrder     Int     @default(0) @map("sort_order")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  amenity Amenity @relation(fields: [amenityId], references: [id], onDelete: Cascade)

  @@id([projectId, amenityId])
  @@index([amenityId])
  @@map("project_amenities")
}

model UnitConfiguration {
  id           String  @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  slug         String  @unique @db.VarChar(48)
  name         String  @unique @db.VarChar(64)
  bedrooms     Int?    @db.SmallInt
  isCommercial Boolean @default(false) @map("is_commercial")
  sortOrder    Int     @default(0) @map("sort_order")

  projectUnitTypes ProjectUnitType[]

  @@map("unit_configurations")
}

model ProjectUnitType {
  id              String   @id @default(dbgenerated("uuid_generate_v7()")) @db.Uuid
  projectId       String   @map("project_id") @db.Uuid
  configurationId String   @map("configuration_id") @db.Uuid
  label           String?  @db.VarChar(120)
  carpetArea      Decimal? @map("carpet_area") @db.Decimal(12, 2)
  builtUpArea     Decimal? @map("built_up_area") @db.Decimal(12, 2)
  superArea       Decimal? @map("super_area") @db.Decimal(12, 2)
  areaUnit        AreaUnit @default(SQFT) @map("area_unit")
  priceMinor      BigInt?  @map("price_minor")
  currency        Currency @default(INR)
  totalUnits      Int?     @map("total_units")
