# =============================================================================
# JMS GROUP — ENVIRONMENT
#
# Copy to `.env.local` and fill in. `.env.local` is gitignored and must never
# be committed: it holds the signing secret and the operator password hashes.
# =============================================================================

# --- Authentication ----------------------------------------------------------

# Signs the session cookie. Must be at least 32 characters of random data, and
# must differ per environment. Rotating it signs everyone out, which is the
# intended way to revoke every session at once.
#
# Generate one:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
#
# Required in production — the app refuses to authenticate without it rather
# than falling back to a shared default.
AUTH_SECRET=

# Operator accounts, one per line, as:
#   email|Display Name|role|password-hash
#
# Roles: owner | admin | editor | viewer
#   owner   — full access, including managing other operators
#   admin   — full access except managing operators
#   editor  — content and leads
#   viewer  — read-only
#
# Generate a password hash (never store a plain password here):
#   npm run auth:hash -- 'the-password'
#
# The hash is dot-separated base64url on purpose: env values are run through
# variable expansion, so a `$`-delimited hash would be silently eaten and the
# account could never sign in. Paste the generated value exactly as printed.
#
# Example (the hash below is a placeholder, not a working credential):
# ADMIN_USERS="ops@jmsgroup.co.in|Priya Nair|owner|pbkdf2.210000.SALT.HASH"
ADMIN_USERS=

# --- Database (Supabase PostgreSQL) ------------------------------------------

# Pooled connection (PgBouncer, port 6543). What the application uses: a
# serverless function opens a connection per invocation and would otherwise
# exhaust max_connections. Keep `?pgbouncer=true`.
DATABASE_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true

# Direct/session connection (port 5432). Migrations only — Prisma Migrate takes
# advisory locks and runs DDL in transactions, neither of which survives
# transaction-mode pooling. `DIRECT_DATABASE_URL` is accepted as an alias.
DIRECT_URL=postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# connect_timeout and pool_timeout are applied in code (src/lib/db.ts) rather
# than here — a distant pooler routinely takes longer than Prisma's 5s default
# to complete a handshake, which otherwise surfaces as an intermittent P1001.

# Set to "true" to log every SQL statement. Development only: query logs are
# both noise and a route for personal data to reach a log aggregator.
# PRISMA_LOG_QUERIES=false

# --- Supabase Storage --------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Bypasses every storage policy. Server-only — never expose it to the browser,
# and never give it a NEXT_PUBLIC_ prefix. Anything holding this key can read
# every résumé and private document in the project.
SUPABASE_SERVICE_ROLE_KEY=

# --- SEO ---------------------------------------------------------------------

# The canonical origin for this deployment, with no trailing slash. Leave unset
# in production to use the real domain; set it on preview and staging so those
# builds do not advertise production canonicals and sitemaps.
# NEXT_PUBLIC_SITE_URL=https://staging.jmsgroup.co.in
